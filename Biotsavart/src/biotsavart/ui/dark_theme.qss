QMainWindow {
    background-color: #1E1E1E;
}

QWidget {
    background-color: #1E1E1E;
    color: white;
}

QGroupBox {
    border: 1px solid #444444;
    border-radius: 6px;
    margin-top: 10px;
    padding-top: 8px;
}

QPushButton {
    background-color: #2563EB;
    color: white;
    border-radius: 5px;
    padding: 5px;
}